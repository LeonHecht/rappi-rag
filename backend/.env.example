APP_ENV=local
API_VERSION=v1
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173

# bm25 is easiest for local development. Use opensearch when a cluster is running.
SEARCH_BACKEND=bm25
CORPUS_PATH=data/static_corpus
DATA_UPLOAD=backend/app/api/data/user_uploads

OPENSEARCH_HOSTS=http://localhost:9200
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_INDEX_PREFIX=rag-template

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5-nano

SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_JWKS_URL=
SUPABASE_JWT_SECRET=

STRIPE_SECRET_KEY=
BILLING_RETURN_URL=http://localhost:5173/settings/billing
FRONTEND_BASE_URL=http://localhost:5173
